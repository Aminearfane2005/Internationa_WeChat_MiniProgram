/* ===== GLOBAL LOGIN GATEWAY ===== */
.login-gateway {
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  z-index: 99999;
  background: linear-gradient(135deg, #232F3E 0%, #0F1111 100%);
  display: flex;
  justify-content: center;
  align-items: center;
  margin-top: 190px;
}

.glass-card {
  width: 85%;
  padding: 60rpx 40rpx;
  background: rgba(255, 255, 255, 0.98);
  border-radius: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 40rpx 100rpx rgba(0,0,0,0.5);
}

.connect-button {
  width: 100%;
  height: 100rpx;
  background: #07C160; 
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50rpx;
  font-weight: bold;
  margin-top: 40rpx;
}

.wechat-icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 15rpx;
}

/* Pulse Animation for Logo */
.pulse-ring {
  position: absolute;
  width: 200rpx;
  height: 200rpx;
  background: rgba(255, 164, 28, 0.2);
  border-radius: 50%;
  animation: pulse 2s infinite;
}

@keyframes pulse {
  0% { transform: scale(0.9); opacity: 1; }
  100% { transform: scale(1.5); opacity: 0; }
}