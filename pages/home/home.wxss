.page {
  min-height: 100vh;
  padding: 20rpx 24rpx 40rpx;
  background: linear-gradient(160deg, #080b16 0%, #151b34 45%, #202f63 100%);
  position: relative;
  overflow: hidden;
  margin-top: 100rpx;
}

.ambient {
  position: absolute;
  border-radius: 999rpx;
  filter: blur(20rpx);
  opacity: 0.45;
}

.ambient.one {
  width: 260rpx;
  height: 260rpx;
  top: -80rpx;
  left: -60rpx;
  background: #43d0ff;
}

.ambient.two {
  width: 300rpx;
  height: 300rpx;
  right: -100rpx;
  top: 320rpx;
  background: #9c72ff;
}

.glass {
  background: rgba(255, 255, 255, 0.08);
  border: 1rpx solid rgba(255, 255, 255, 0.24);
  box-shadow: 0 24rpx 60rpx rgba(6, 10, 28, 0.4);
}

.top-user {
  position: relative;
  z-index: 2;
  margin-top: 6rpx;
  border-radius: 26rpx;
  padding: 20rpx;
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.top-avatar {
  width: 84rpx;
  height: 84rpx;
  border-radius: 50%;
  border: 3rpx solid rgba(255, 255, 255, 0.7);
}

.top-meta {
  flex: 1;
}

.top-greeting {
  display: block;
  font-size: 21rpx;
  color: rgba(255, 255, 255, 0.82);
}

.top-name {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #ffffff;
  margin-top: 4rpx;
}

.top-chip {
  font-size: 22rpx;
  font-weight: 600;
  color: #fff;
  border-radius: 999rpx;
  padding: 8rpx 18rpx;
  background: linear-gradient(120deg, #1dd1ff, #6f7dff);
}

.home-scroll {
  position: relative;
  z-index: 2;
  margin-top: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.hero {
  border-radius: 34rpx;
  padding: 30rpx;
}

.hero-badge {
  width: fit-content;
  font-size: 20rpx;
  color: #c9ebff;
  border-radius: 999rpx;
  padding: 8rpx 16rpx;
  background: rgba(103, 215, 255, 0.2);
}

.hero-title {
  display: block;
  margin-top: 16rpx;
  font-size: 50rpx;
  line-height: 1.2;
  font-weight: 700;
  color: #ffffff;
}

.hero-subtitle {
  display: block;
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 1.5;
  color: rgba(255, 255, 255, 0.85);
}

.stats-row {
  margin-top: 24rpx;
  display: flex;
  gap: 14rpx;
}

.stat-item {
  flex: 1;
  border-radius: 20rpx;
  padding: 18rpx 12rpx;
  background: rgba(255, 255, 255, 0.1);
  text-align: center;
}

.stat-value {
  display: block;
  color: #fff;
  font-size: 31rpx;
  font-weight: 700;
}

.stat-label {
  display: block;
  margin-top: 6rpx;
  color: rgba(255, 255, 255, 0.82);
  font-size: 19rpx;
}

.hero-cta {
  margin-top: 24rpx;
  border-radius: 20rpx;
  padding: 20rpx 24rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: linear-gradient(130deg, #12d5ff, #4d88ff, #7c62ff);
}

.hero-cta-text {
  color: #fff;
  font-size: 28rpx;
  font-weight: 700;
}

.hero-arrow {
  color: #fff;
  font-size: 34rpx;
}

.section-head {
  padding: 2rpx 4rpx;
}

.section-title {
  display: block;
  color: #fff;
  font-size: 34rpx;
  font-weight: 700;
}

.section-subtitle {
  display: block;
  margin-top: 6rpx;
  color: rgba(255, 255, 255, 0.76);
  font-size: 23rpx;
}

.feature-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.feature-card {
  width: 48%;
  margin-bottom: 18rpx;
  box-sizing: border-box;
  border-radius: 26rpx;
  padding: 20rpx;
  min-height: 220rpx;
  box-shadow: 0 18rpx 40rpx rgba(0, 0, 0, 0.25);
}

.feature-icon {
  font-size: 42rpx;
}

.feature-title {
  display: block;
  margin-top: 16rpx;
  color: #fff;
  font-size: 28rpx;
  font-weight: 700;
}

.feature-desc {
  display: block;
  margin-top: 8rpx;
  color: rgba(255, 255, 255, 0.87);
  font-size: 21rpx;
  line-height: 1.45;
}

.travel {
  background: linear-gradient(150deg, #00c6ff 0%, #0072ff 100%);
}

.secondHand {
  background: linear-gradient(150deg, #ff5f6d 0%, #ffc371 100%);
}

.community {
  background: linear-gradient(150deg, #6a11cb 0%, #2575fc 100%);
}

.house {
  background: linear-gradient(150deg, #00b09b 0%, #96c93d 100%);
}

.sharing {
  background: linear-gradient(150deg, #ff6fd8 0%, #6f7dff 100%);
}

.highlight {
  border-radius: 30rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  box-shadow: 0 20rpx 50rpx rgba(0, 0, 0, 0.28);
}

.highlight-title {
  display: block;
  color: #fff;
  font-size: 32rpx;
  font-weight: 700;
}

.highlight-subtitle {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.9);
}

.highlight-action {
  border-radius: 999rpx;
  padding: 12rpx 20rpx;
  color: #332a66;
  font-size: 22rpx;
  font-weight: 700;
  background: #fff;
}

.trust-strip {
  border-radius: 24rpx;
  padding: 22rpx 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-wrap: wrap;
  gap: 10rpx;
}

.trust-item {
  color: #fff;
  font-size: 21rpx;
}

.trust-dot {
  color: rgba(255, 255, 255, 0.66);
}

.loading {
  margin-top: 30rpx;
  color: rgba(255, 255, 255, 0.82);
  font-size: 24rpx;
  text-align: center;
}