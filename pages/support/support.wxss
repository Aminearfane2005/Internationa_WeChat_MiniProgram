/* --- Global Container --- */
/* Update your page reset */
page {
  height: 100vh;
  overflow: hidden; /* This is crucial! */
  display: flex;
  flex-direction: column;
}
.fixed-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: 88rpx;
    background: linear-gradient(135deg, #0ea5e9, #14b8a6);
    display: flex;
    align-items: center;
    padding: 0 30rpx;
    z-index: 1000;
  }
  
  .back-btn {
    display: flex;
    align-items: center;
    color: white;
  }
  
  .back-icon {
    font-size: 40rpx;
    margin-right: 10rpx;
  }
  
  .back-text {
    font-size: 28rpx;
  }
  
  .page-title {
    color: white;
    font-size: 32rpx;
    font-weight: bold;
    margin-left: 30rpx;
  }
.app-shell {
  background: #f0f2f5;
  height: 100vh; /* Change min-height to height */
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

/* --- Glassmorphic Navigation --- */
.nav-blur {
  background: rgba(255, 255, 255, 0.75);
  backdrop-filter: blur(25px);
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.3);
  position: sticky;
  top: 0;
  z-index: 100;
}

/* --- Chat Engine (The Scroll Area) --- */
.chat-engine {
  flex: 1;
  padding-bottom: 40rpx;
}

.message-container {
  padding: 40rpx 30rpx;
  display: flex;
  flex-direction: column;
}

/* --- Message Rows --- */
.msg-row {
  display: flex;
  margin-bottom: 35rpx;
  width: 100%;
  animation: fadeIn 0.3s ease-out;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(10rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.msg-bubble {
  max-width: 75%;
  padding: 24rpx 32rpx;
  font-size: 28rpx;
  line-height: 1.6;
  position: relative;
  box-shadow: 0 8rpx 20rpx rgba(0, 0, 0, 0.04);
}

/* --- User (Left) Styling: "The Clean White Look" --- */
.is-user {
  justify-content: flex-start;
}

.is-user .msg-bubble {
  background: #ffffff;
  color: #1d1d1f;
  border-radius: 40rpx 40rpx 40rpx 10rpx;
  border: 1rpx solid rgba(0, 0, 0, 0.02);
}

/* --- Admin (Right) Styling: "The Blue Legend Gradient" --- */
.is-admin {
  justify-content: flex-end;
}

.is-admin .msg-bubble {
  background: linear-gradient(135deg, #007aff, #0055ff);
  color: #ffffff;
  border-radius: 40rpx 40rpx 10rpx 40rpx;
}

.msg-time {
  display: block;
  font-size: 20rpx;
  margin-top: 10rpx;
  opacity: 0.5;
  font-weight: 300;
}

.is-admin .msg-time {
  color: rgba(255, 255, 255, 0.8);
  text-align: right;
}

/* --- Floating Input Shelf --- */
.input-shelf {
  padding: 20rpx 30rpx calc(env(safe-area-inset-bottom) + 20rpx);
  background: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(20px);
  border-top: 1rpx solid rgba(0, 0, 0, 0.05);
}

.input-pill {
  display: flex;
  align-items: center;
  background: #f2f2f7;
  border-radius: 50rpx;
  padding: 12rpx 12rpx 12rpx 35rpx;
  transition: all 0.2s ease;
}

.input-pill:focus-within {
  background: #ffffff;
  box-shadow: 0 0 0 4rpx rgba(0, 122, 255, 0.15);
}

.main-input {
  flex: 1;
  height: 70rpx;
  font-size: 30rpx;
  color: #1d1d1f;
}

/* --- Send Button (Matching your cs-pulse vibe) --- */
.send-btn {
  width: 76rpx !important;
  height: 76rpx !important;
  border-radius: 50% !important;
  background: #007aff;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 20rpx;
  padding: 0;
  box-shadow: 0 4rpx 12rpx rgba(0, 122, 255, 0.3);
}

.send-btn:active {
  transform: scale(0.92);
  background: #005bc5;
}

.send-btn text {
  color: white;
  font-size: 32rpx;
}
/* Container for the image and nav */
.chat-header-area {
  flex-shrink: 0; /* Prevents header from squishing */
  position: relative;
  width: 100%;
  height: 320rpx;
  overflow: hidden;
}
/* 4. Fix the Scroll Engine */
.chat-engine {
  flex: 1;
  height: 0; /* Crucial for scrolling inside flex */
  overflow-y: scroll;
}

/* 5. Ensure Input Shelf stays at bottom */
.input-shelf {
  flex-shrink: 0; /* Prevents input area from squishing */
  padding: 20rpx 30rpx calc(env(safe-area-inset-bottom) + 20rpx);
  background: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(20px);
  border-top: 1rpx solid rgba(0, 0, 0, 0.05);
}
/* The actual banner image */
.header-banner {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 1;
}

/* Adjusted nav-blur to sit on top of the image */
.nav-blur {
  /* Change 15px to 2px or 0px if you want it perfectly clear */
  backdrop-filter: blur(0px); 
  
  /* You can also lighten the gradient if the image looks too dark */
  background: linear-gradient(to bottom, rgba(0,0,0,0.1), rgba(240, 242, 245, 0.7));
}

/* Ensure text is readable over the banner */
.u-name {
  color: #ffffff;
  font-weight: 600;
  text-shadow: 0 2rpx 4rpx rgba(0,0,0,0.3);
}

.u-id {
  color: rgba(255,255,255,0.9);
  font-size: 22rpx;
}
/* Add this to your CSS for the status indicator */
.status-glow {
  width: 12rpx;
  height: 12rpx;
  background: #34c759; /* Bright Apple Green */
  border-radius: 50%;
  border: 2rpx solid #fff;
  box-shadow: 0 0 10rpx rgba(52, 199, 89, 0.6);
}
.back-btn {
  position: absolute;
  left: 30rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 70rpx;
  height: 70rpx;
  /* Change background to a darker semi-transparent circle */
  background: rgba(0, 0, 0, 0.3); 
  backdrop-filter: blur(10px);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  /* Make sure it sits on the very top layer */
  z-index: 999; 
  border: 1rpx solid rgba(255, 255, 255, 0.2);
}

.back-icon {
  color: #ffffff;
  font-size: 40rpx;
  font-weight: bold;
}