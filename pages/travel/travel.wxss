page {
    margin: 0;
    padding: 0;
    background: #f5f7fa;
    height: 100%;
  }
  
  .container {
    margin: 0;
    padding: 0;
    background: #f5f7fa;
    min-height: 100vh;
    position: relative;
  }
  
  /* ========== FIXED HEADER ========== */
  .fixed-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    background: #f5f7fa;
    z-index: 100;
    padding-bottom: 20rpx;
  }
  
  .travel-banner {
    background: linear-gradient(135deg, rgba(14,165,233,0.9) 0%, rgba(20,184,166,0.9) 100%);
    padding: 70rpx 30rpx;
  }
  
  .banner-content {
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  
  .banner-title {
    font-size: 52rpx;
    color: #fff;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 4rpx;
  }
  
  .banner-subtitle {
    font-size: 28rpx;
    color: rgba(255,255,255,0.9);
    margin-top: 10rpx;
  }
  
  /* ========== SEARCH BOX ========== */
  .search-box {
    display: flex;
    align-items: center;
    background: #fff;
    width: 90%;
    margin: 20rpx auto 0;
    border-radius: 40rpx;
    padding: 20rpx 32rpx;
    box-shadow: 0 4rpx 16rpx rgba(0,0,0,.08);
    position: relative;
  }
  
  .search-box .iconfont {
    font-size: 32rpx;
    color: #999;
    margin-right: 16rpx;
  }
  
  .search-box input {
    flex: 1;
    font-size: 30rpx;
    color: #333;
    height: 40rpx;
    line-height: 40rpx;
  }
  
  .clear-search {
    position: absolute;
    right: 80rpx;
    color: #999;
    font-size: 32rpx;
    padding: 10rpx;
  }
  
  /* ========== SEARCH SUGGESTIONS ========== */
  .search-suggestions {
    position: absolute;
    top: 100%;
    left: 5%;
    right: 5%;
    background: #fff;
    border-radius: 20rpx;
    box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.15);
    z-index: 200;
    max-height: 400rpx;
    overflow-y: auto;
    margin-top: 10rpx;
  }
  
  .suggestion-item {
    display: flex;
    align-items: center;
    padding: 24rpx 32rpx;
    border-bottom: 1rpx solid #f0f0f0;
  }
  
  .suggestion-item:active {
    background: #f5f7fa;
  }
  
  .suggestion-icon {
    font-size: 32rpx;
    margin-right: 16rpx;
  }
  
  .suggestion-text {
    font-size: 30rpx;
    color: #333;
  }
  
  /* ========== CITY TABS ========== */
  .city-tabs-wrapper {
    width: 100%;
    padding: 10rpx 0 0;
    overflow: hidden;
    background: #f5f7fa;
  }
  
  .city-tabs-scroll {
    width: 100%;
    height: 90rpx;
    white-space: nowrap;
  }
  
  .city-tabs-container {
    display: inline-flex;
    flex-direction: row;
    padding: 0 20rpx;
    align-items: center;
    height: 100%;
  }
  
  .city-btn {
    flex-shrink: 0;
    margin: 0 10rpx;
    padding: 16rpx 32rpx;
    height: 70rpx;
    line-height: 38rpx;
    font-size: 28rpx;
    color: #fff;
    background: #0ea5e9;
    border-radius: 40rpx;
    text-align: center;
    border: none;
    min-width: 140rpx;
  }
  
  .city-btn::after {
    border: none;
  }
  
  .city-btn.active {
    background: #0284c7;
  }
  
  .city-btn.other {
    background: #f59e0b;
  }
  
  .city-btn.other.active {
    background: #d97706;
  }
  
  /* ========== OTHER CITY INPUT ========== */
  .other-city-box {
    display: flex;
    align-items: center;
    margin: 20rpx 30rpx;
    padding: 20rpx;
    background: #fff;
    border-radius: 20rpx;
    box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.1);
  }
  
  .other-city-box input {
    flex: 1;
    background: #f5f7fa;
    padding: 20rpx;
    border-radius: 16rpx;
    font-size: 30rpx;
    margin-right: 20rpx;
  }
  
  .confirm-btn {
    background: #14b8a6;
    color: #fff;
    font-size: 28rpx;
    padding: 16rpx 32rpx;
    border-radius: 16rpx;
    border: none;
    margin: 0;
  }
  
  .confirm-btn::after {
    border: none;
  }
  
  /* ========== FILTER CHIPS ========== */
  .filter-chips {
    display: flex;
    flex-direction: row;
    gap: 12rpx;
    padding: 20rpx;
    width: 100%;
    box-sizing: border-box;
    justify-content: space-between;
  }
  
  .chip {
    flex: 1;
    min-width: 0;
    height: 80rpx;
    line-height: 80rpx;
    border-radius: 12rpx;
    font-size: 24rpx;
    text-align: center;
    background: #f5f5f5;
    color: #666;
    border: none;
    margin: 0;
    padding: 0 10rpx;
    white-space: nowrap;
    overflow: visible;
  }
  
  .chip::after {
    border: none;
  }
  
  .chip.active {
    background: #14b8a6;
    color: #fff;
    font-weight: 600;
    box-shadow: 0 4rpx 12rpx rgba(20, 184, 166, 0.3);
  }
  
  /* ========== SCROLLABLE CONTENT ========== */
  .page-scroll {
    height: 100vh;
    padding-top: 650rpx;
    padding-bottom: 120rpx;
    box-sizing: border-box;
  }
  
  /* ========== POST LIST ========== */
  .post-list {
    padding: 0 20rpx;
    width: 100%;
    box-sizing: border-box;
  }
  
  /* ========== POST CARD ========== */
  .post-card {
    display: flex;
    flex-direction: column;
    background: #fff;
    border-radius: 24rpx;
    padding: 30rpx;
    margin-bottom: 30rpx;
    box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.08);
    width: 100%;
    box-sizing: border-box;
  }
  
  /* ========== POST HEADER ========== */
  .post-header {
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 20rpx;
    width: 100%;
    position: relative;  /* ADD THIS */
  }
  
  .user-info {
    display: flex;
    flex-direction: row;
    align-items: center;
    flex: 1;
    min-width: 0;
    overflow: hidden;
  }
  
  .user-avatar {
    width: 80rpx;
    height: 80rpx;
    border-radius: 50%;
    margin-right: 16rpx;
    flex-shrink: 0;
    background: #e5e7eb;
  }
  
  .user-name {
    font-size: 30rpx;
    font-weight: 600;
    color: #333;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    max-width: 300rpx;
  }
  
  .post-time {
    font-size: 24rpx;
    color: #999;
    flex-shrink: 0;
    margin-left: 16rpx;
  }
  
  /* ========== POST CONTENT ========== */
  .post-title {
    font-size: 32rpx;
    font-weight: 700;
    color: #222;
    margin-bottom: 12rpx;
    line-height: 1.4;
    display: block;
  }
  
  .post-desc {
    font-size: 28rpx;
    color: #555;
    line-height: 1.6;
    margin-bottom: 16rpx;
    display: -webkit-box;
    -webkit-line-clamp: 5;
    -webkit-box-orient: vertical;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  
  /* ========== IMAGES ========== */
  .post-image-single {
    width: 100%;
    height: 400rpx;
    margin-bottom: 16rpx;
    border-radius: 12rpx;
    overflow: hidden;
    background-color: #f0f0f0;
  }
  
  .post-image-single image {
    width: 100%;
    height: 100%;
  }
  
  .post-images-grid {
    display: grid;
    gap: 8rpx;
    margin-bottom: 16rpx;
    border-radius: 12rpx;
    overflow: hidden;
    width: 100%;
  }
  
  /* 2 images - side by side */
  .grid-2 {
    grid-template-columns: repeat(2, 1fr);
    height: 320rpx;
  }
  
  /* 3 images - first big, 2 stacked right */
  .grid-3 {
    grid-template-columns: 2fr 1fr;
    grid-template-rows: repeat(2, 1fr);
    height: 400rpx;
  }
  
  .grid-3 .post-image-item:first-child {
    grid-row: span 2;
  }
  
  /* 4 images - 2x2 grid */
  .grid-4 {
    grid-template-columns: repeat(2, 1fr);
    grid-template-rows: repeat(2, 1fr);
    height: 400rpx;
  }
  
  .post-image-item {
    position: relative;
    overflow: hidden;
    border-radius: 8rpx;
    background-color: #f0f0f0;
    width: 100%;
    height: 100%;
  }
  
  .post-image-item image {
    width: 100%;
    height: 100%;
  }
  
  .more-images-overlay {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0, 0, 0, 0.6);
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 12rpx;
  }
  
  .more-images-text {
    color: #fff;
    font-size: 40rpx;
    font-weight: bold;
  }
  
  .image-counter-badge {
    display: inline-flex;
    align-items: center;
    background: rgba(0, 0, 0, 0.6);
    border-radius: 20rpx;
    padding: 8rpx 16rpx;
    margin-bottom: 16rpx;
    align-self: flex-start;
  }
  
  .counter-badge-text {
    color: #fff;
    font-size: 24rpx;
    font-weight: 500;
  }
  
  /* ========== POST FOOTER ========== */
  .post-footer {
    display: flex;
    flex-direction: row;
    justify-content: space-between;
    align-items: center;
    width: 100%;
    padding-top: 20rpx;
    border-top: 1rpx solid #f0f0f0;
    flex-wrap: wrap;
    gap: 16rpx;
  }
  
  .post-info {
    display: flex;
    flex-direction: row;
    gap: 16rpx;
    align-items: center;
    flex: 1;
    flex-wrap: wrap;
  }
  
  .info-item {
    display: inline-flex;
    align-items: center;
    gap: 6rpx;
    white-space: nowrap;
    background: #f5f7fa;
    padding: 8rpx 16rpx;
    border-radius: 12rpx;
  }
  
  .info-icon {
    font-size: 24rpx;
  }
  
  .info-text {
    font-size: 24rpx;
    color: #666;
  }
  
  .info-item.spots {
    background: #e6fffa;
  }
  
  .info-item.spots .info-text {
    color: #14b8a6;
    font-weight: 600;
  }
  
  .post-actions {
    display: flex;
    flex-direction: row;
    gap: 24rpx;
    align-items: center;
    flex-shrink: 0;
  }
  
  .action-btn {
    display: flex;
    align-items: center;
    gap: 6rpx;
    background: none;
    border: none;
    padding: 10rpx;
    margin: 0;
    font-size: 24rpx;
    color: #666;
    line-height: 1;
  }
  
  .action-btn::after {
    border: none;
  }
  
  .action-icon {
    font-size: 32rpx;
  }
  
  .action-num {
    font-size: 24rpx;
    color: #666;
    font-weight: 500;
    min-width: 20rpx;
    text-align: center;
  }
  
  .action-btn.liked .action-icon,
  .action-btn.liked .action-num {
    color: #ff4757;
  }
  
  /* Edit/Delete buttons */
  .post-actions-right {
    display: flex;
    flex-direction: row;
    gap: 16rpx;
    align-items: center;
    margin-left: auto;
  }
  
  .edit-btn .action-icon,
  .delete-btn .action-icon {
    font-size: 32rpx;
  }
  
  .edit-btn:active,
  .delete-btn:active {
    opacity: 0.6;
  }
  
  /* Empty state */
  .empty-state {
    text-align: center;
    padding: 100rpx 0;
  }
  
  .empty-text {
    font-size: 28rpx;
    color: #999;
    display: block;
    margin-bottom: 40rpx;
  }
  
  .create-first-btn {
    background: #14b8a6;
    color: white;
    border-radius: 40rpx;
    padding: 20rpx 40rpx;
    font-size: 28rpx;
    border: none;
  }
  
  .create-first-btn::after {
    border: none;
  }
  
  /* ========== FAB MENU ========== */
  .fab-wrapper {
    position: fixed;
    right: 30rpx;
    bottom: 150rpx;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    z-index: 1000;
  }
  
  .fab-button {
    width: 112rpx;
    height: 112rpx;
    border-radius: 50%;
    background: linear-gradient(135deg, #14b8a6, #0ea5e9);
    box-shadow: 0 8rpx 24rpx rgba(20, 184, 166, 0.4);
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-size: 48rpx;
    transition: all 0.3s;
  }
  
  .fab-button.active {
    transform: rotate(45deg);
    background: linear-gradient(135deg, #ef4444, #f97316);
  }
  
  .fab-icon {
    font-size: 48rpx;
  }
  
  .fab-menu {
    margin-bottom: 20rpx;
    opacity: 0;
    transform: translateY(20rpx);
    transition: all 0.3s;
    pointer-events: none;
  }
  
  .fab-menu.show {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }
  
  .menu-item {
    background: white;
    padding: 24rpx 36rpx;
    border-radius: 40rpx;
    box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.15);
    font-size: 28rpx;
    color: #333;
    margin-bottom: 16rpx;
    white-space: nowrap;
  }
  
  /* ========== COMMENT POPUP ========== */
  .comment-overlay {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0, 0, 0, 0.6);
    z-index: 10000;
    display: flex;
    align-items: flex-end;
  }
  
  .comment-popup {
    width: 100%;
    height: 70vh;
    background: #fff;
    border-radius: 24rpx 24rpx 0 0;
    display: flex;
    flex-direction: column;
  }
  
  .comment-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 30rpx;
    border-bottom: 1rpx solid #f0f0f0;
  }
  
  .comment-title {
    font-size: 32rpx;
    font-weight: 600;
    color: #333;
  }
  
  .comment-close {
    font-size: 40rpx;
    color: #999;
    padding: 10rpx;
  }
  
  .comment-list {
    flex: 1;
    padding: 20rpx 30rpx;
    overflow-y: auto;
  }
  
  .comment-item {
    display: flex;
    margin-bottom: 30rpx;
  }
  
  .comment-avatar {
    width: 80rpx;
    height: 80rpx;
    border-radius: 50%;
    margin-right: 20rpx;
    flex-shrink: 0;
  }
  
  .comment-content {
    flex: 1;
    background: #f5f7fa;
    border-radius: 16rpx;
    padding: 20rpx;
  }
  
  .comment-name {
    font-size: 28rpx;
    font-weight: 600;
    color: #333;
    display: block;
    margin-bottom: 8rpx;
  }
  
  .comment-text {
    font-size: 28rpx;
    color: #666;
    line-height: 1.5;
    display: block;
    margin-bottom: 8rpx;
  }
  
  .comment-time {
    font-size: 22rpx;
    color: #999;
  }
  
  .comment-empty {
    text-align: center;
    padding: 100rpx 0;
    color: #999;
    font-size: 28rpx;
  }
  
  .comment-input-area {
    display: flex;
    align-items: center;
    padding: 20rpx 30rpx;
    border-top: 1rpx solid #f0f0f0;
    padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  }
  
  .comment-input {
    flex: 1;
    height: 80rpx;
    background: #f5f7fa;
    border-radius: 40rpx;
    padding: 0 30rpx;
    font-size: 28rpx;
    margin-right: 20rpx;
  }
  
  .comment-send {
    background: #14b8a6;
    color: #fff;
    font-size: 28rpx;
    padding: 20rpx 40rpx;
    border-radius: 40rpx;
    border: none;
  }
  
  .comment-send::after {
    border: none;
  }

  /* ========== DELETE POPUP ========== */
  .delete-overlay {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0, 0, 0, 0.6);
    z-index: 10001;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  
  .delete-popup {
    width: 560rpx;
    background: #fff;
    border-radius: 32rpx;
    padding: 48rpx 40rpx 40rpx;
    text-align: center;
  }
  
  .delete-title {
    font-size: 36rpx;
    font-weight: 600;
    color: #333;
    margin-bottom: 20rpx;
  }
  
  .delete-message {
    font-size: 28rpx;
    color: #666;
    margin-bottom: 40rpx;
    line-height: 1.5;
  }
  
  .delete-actions {
    display: flex;
    gap: 20rpx;
  }
  
  .delete-cancel {
    flex: 1;
    background: #f5f5f5;
    color: #666;
    border-radius: 40rpx;
    padding: 20rpx;
    font-size: 28rpx;
    border: none;
  }
  
  .delete-confirm {
    flex: 1;
    background: #ff4757;
    color: #fff;
    border-radius: 40rpx;
    padding: 20rpx;
    font-size: 28rpx;
    border: none;
  }
  
  .delete-cancel::after,
  .delete-confirm::after {
    border: none;
  }

  /* ========== POST MENU (3 DOTS) ========== */
.post-menu-wrapper {
    position: relative;
    margin-left: auto;
    flex-shrink: 0;
  }
  
  .menu-dots-btn {
    width: 60rpx;
    height: 60rpx;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    padding: 0;
    margin: 0;
    background: none;
    border: none;
  }
  
  .menu-dots-btn::after {
    border: none;
  }
  
  .menu-dots-btn:active {
    background: rgba(0, 0, 0, 0.05);
  }
  
  .dots-icon {
    font-size: 40rpx;
    color: #999;
    font-weight: bold;
    line-height: 1;
    transform: rotate(90deg);
    display: block;
  }
  
  /* ========== POST OPTIONS POPUP ========== */
  .post-options-overlay {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0, 0, 0, 0.5);
    z-index: 10002;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  
  .post-options-popup {
    width: 560rpx;
    background: #fff;
    border-radius: 24rpx;
    overflow: hidden;
    box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.2);
    animation: popupSlideUp 0.2s ease-out;
  }
  
  @keyframes popupSlideUp {
    from {
      opacity: 0;
      transform: translateY(40rpx);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  
  .post-option-item {
    display: flex;
    align-items: center;
    padding: 32rpx 40rpx;
    gap: 20rpx;
  }
  
  .post-option-item:active {
    background: #f5f7fa;
  }
  
  .option-icon {
    font-size: 36rpx;
    width: 48rpx;
    text-align: center;
  }
  
  .option-text {
    font-size: 30rpx;
    color: #333;
    font-weight: 500;
  }
  
  .delete-text {
    color: #ff4757;
  }
  
  .post-option-divider {
    height: 1rpx;
    background: #f0f0f0;
    margin: 0 40rpx;
  }