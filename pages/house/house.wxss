.page {
  min-height: 100vh;
  background: #f6f7f9;
  margin-top: 180rpx;

}
.fixed-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: 88rpx;
    background: linear-gradient(135deg, #0ea5e9, #14b8a6);
    display: flex;
    align-items: center;
    padding: 0 30rpx;
    z-index: 1000;
  }
  
  .back-btn {
    display: flex;
    align-items: center;
    color: white;
  }
  
  .back-icon {
    font-size: 40rpx;
    margin-right: 10rpx;
  }
  
  .back-text {
    font-size: 28rpx;
  }
  
  .page-title {
    color: white;
    font-size: 32rpx;
    font-weight: bold;
    margin-left: 30rpx;
  }
/* ===== BANNER ===== */
.top-banner {
  width: 100%;
  height: 360rpx;
}

/* ===== TABS ===== */
.tabs {
  display: flex;
  background: #fff;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 28rpx 0;
  font-size: 30rpx;
  color: #888;
}

.tab.active {
  color: #1aad19;
  font-weight: bold;
  border-bottom: 4rpx solid #1aad19;
}

/* ===== VIEW SECTION ===== */
.house-list {
  padding: 24rpx;
}

.house-card {
  background: #fff;
  border-radius: 24rpx;
  margin-bottom: 32rpx;
  overflow: hidden;
  box-shadow: 0 10rpx 25rpx rgba(0,0,0,0.08);
  position: relative;
}
.tab-bar-spacer {
  /* This creates enough empty space at the bottom for the tab bar */
  height: calc(120rpx + env(safe-area-inset-bottom));
  width: 100%;
  pointer-events: none;
}
/* Swiper for house images */
.house-swiper {
  height: 360rpx;
  border-bottom-left-radius: 24rpx;
  border-bottom-right-radius: 24rpx;
}

.house-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

/* Price tag overlay */
.price-tag {
  position: absolute;
  top: 24rpx;
  left: 24rpx;
  background: rgba(26, 173, 25, 0.9);
  color: #fff;
  padding: 12rpx 20rpx;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: bold;
  z-index: 10;
}

/* Info section */
.house-info {
  padding: 24rpx;
}

.description {
  font-size: 28rpx;
  color: #555;
  line-height: 38rpx;
}

/* Contact button at bottom */
.contact-btn {
  margin: 0 24rpx 24rpx;
  background: #1aad19;
  color: #fff;
  text-align: center;
  padding: 22rpx;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: bold;
  box-shadow: 0 6rpx 12rpx rgba(26, 173, 25, 0.5);
  transition: all 0.2s;
}

.contact-btn:active {
  transform: scale(0.97);
}

/* ===== EMPTY ===== */
.empty {
  text-align: center;
  margin-top: 200rpx;
  color: #999;
}

/* ===== ADD SECTION ===== */
.add-section {
  padding: 24rpx;
 
}

.form-item {
  margin-bottom: 28rpx;
}

.label {
  display: block;
  margin-bottom: 12rpx;
  font-size: 28rpx;
  color: #333;
}

input,
textarea {
  width: 100%;
  padding: 20rpx;
  background: #fff;
  border-radius: 12rpx;
  font-size: 28rpx;
}

textarea {
  min-height: 140rpx;
}

.image-picker {
  background: #fff;
  padding: 28rpx;
  border-radius: 12rpx;
  text-align: center;
  color: #1aad19;
}

.count {
  display: block;
  margin-top: 10rpx;
  color: #999;
}

.submit-btn {
  background: #1aad19;
  color: #fff;
  text-align: center;
  padding: 26rpx;
  border-radius: 16rpx;
  font-size: 32rpx;
  margin-top: 40rpx;
}

.note {
  display: block;
  margin-top: 20rpx;
  text-align: center;
  font-size: 24rpx;
  color: #999;
}
