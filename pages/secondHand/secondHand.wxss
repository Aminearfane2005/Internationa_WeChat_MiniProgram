.fixed-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: 88rpx;
    background: linear-gradient(135deg, #0ea5e9, #14b8a6);
    display: flex;
    align-items: center;
    padding: 0 30rpx;
    z-index: 1000;
  }
  
  .back-btn {
    display: flex;
    align-items: center;
    color: white;
  }
  
  .back-icon {
    font-size: 40rpx;
    margin-right: 10rpx;
  }
  
  .back-text {
    font-size: 28rpx;
  }
  
  .page-title {
    color: white;
    font-size: 32rpx;
    font-weight: bold;
    margin-left: 30rpx;
  }

/* --- 1. CORE LAYOUT --- */
page {
  background-color: #EAEDED;
  color: #0F1111;
  font-family: "Amazon Ember", Arial, sans-serif;
  height: 100vh;
  display: flex;
  flex-direction: column;
  overflow: hidden; /* Crucial: Prevents double-scrolling of the page body */
}

/* --- 2. HEADER & SEARCH --- */
.nav-header {
  background-color: #232F3E;
  padding-top: 50px; /* Space for the system status bar/notch */
  padding-bottom: 20rpx;
  z-index: 1000;
  flex-shrink: 0;
}

.header-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 30rpx 15rpx;
}

.brand-name {
  color: #ffffff;
  font-size: 38rpx;
  font-weight: 700;
}

.admin-badge {
  background-color: #febd69;
  color: #131921;
  font-size: 22rpx;
  font-weight: bold;
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
}

/* Internal Tab Switcher (Shop/Sell/Admin) */
.tabs {
  display: flex;
  background: #232F3E;
  padding: 0 20rpx;
}

.tab {
  flex: 1;
  text-align: center;
  color: #ffffff;
  font-size: 28rpx;
  padding: 20rpx 0;
  border-bottom: 6rpx solid transparent;
}

.tab.active {
  color: #FFA41C;
  font-weight: bold;
  border-bottom: 6rpx solid #FFA41C;
}

.search-bar {
  background: #ffffff;
  height: 80rpx;
  margin: 10rpx 20rpx;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  padding: 0 25rpx;
}

.search-input {
  flex: 1;
  margin-left: 15rpx;
  font-size: 28rpx;
}

/* --- 3. CATEGORY SCROLL --- */
.category-bar {
  white-space: nowrap;
  background: #37475a;
  padding: 15rpx 0;
}

.cat-pill {
  display: inline-block;
  color: #ffffff;
  font-size: 26rpx;
  padding: 10rpx 30rpx;
  margin: 0 10rpx;
  border-radius: 30rpx;
}

.cat-pill.active {
  background: #ffffff;
  color: #232F3E;
  font-weight: bold;
}

/* --- 4. SCROLL AREA --- */
.main-content {
  flex: 1;
  position: relative;
  overflow: hidden;
}

.scroll-area {
  width: 100%;
  /* Dynamically fills remaining space minus safe area */
  height: calc(100vh - 120rpx - 120px - env(safe-area-inset-bottom)); 
}

/* Spacer to prevent content from hiding behind the custom tab bar */
.tab-bar-spacer {
  height: calc(100rpx + env(safe-area-inset-bottom));
  width: 100%;
}

/* --- 5. PRODUCT CARDS --- */
.product-card {
  position: relative; /* Context for the 'Bought' stamp */
  background: #ffffff;
  display: flex;
  padding: 30rpx;
  margin-bottom: 4rpx;
  border-bottom: 1rpx solid #D5D9D9;
}

.prod-img {
  width: 240rpx;
  height: 240rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
}

.prod-info {
  flex: 1;
  padding-left: 25rpx;
  display: flex;
  flex-direction: column;
}

.prod-title {
  font-size: 30rpx;
  font-weight: 500;
  line-height: 1.3;
  color: #0F1111;
}

.prod-cat {
  font-size: 24rpx;
  color: #565959;
  margin-top: 5rpx;
}

.price-row {
  display: flex;
  align-items: flex-start;
  margin: 10rpx 0;
}

.currency { font-size: 24rpx; margin-top: 6rpx; }
.price-val { font-size: 46rpx; font-weight: bold; }

.delivery-text {
  font-size: 24rpx;
  color: #007600; /* Amazon Success Green */
  margin-bottom: 10rpx;
}

.buy-button {
  margin-top: auto;
  border: 1rpx solid #D5D9D9;
  background: #fff;
  font-size: 26rpx;
  border-radius: 50rpx;
  width: 100%;
  line-height: 2.2;
}

.is-sold {
  filter: grayscale(100%);
  opacity: 0.7;
}

.sold-stamp {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%) rotate(-15deg);
  border: 10rpx double #B12704;
  color: #B12704;
  font-size: 60rpx;
  font-weight: 900;
  padding: 10rpx 30rpx;
  z-index: 100;
  background: rgba(255, 255, 255, 0.4);
  text-transform: uppercase;
  pointer-events: none;
}

/* --- 6. SELL TAB FORM --- */
.sell-form {
  padding: 40rpx 30rpx;
}

.form-h1 {
  font-size: 40rpx;
  font-weight: bold;
  margin-bottom: 30rpx;
  display: block;
}

.label {
  font-size: 28rpx;
  font-weight: bold;
  margin-bottom: 15rpx;
  display: block;
}

.req { color: #B12704; }

.photo-upload {
  width: 100%;
  height: 400rpx;
  background: #f7f7f7;
  border: 2rpx dashed #adb1b8;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 30rpx;
  overflow: hidden;
}

.photo-upload.small { height: 200rpx; width: 200rpx; }

.photo-upload image { width: 100%; height: 100%; }

.amz-input, .picker-box {
  background: #fff;
  border: 1rpx solid #888C8C;
  height: 90rpx;
  padding: 0 24rpx;
  border-radius: 8rpx;
  margin-bottom: 30rpx;
  display: flex;
  align-items: center;
  font-size: 30rpx;
}

.amz-textarea {
  background: #fff;
  border: 1rpx solid #888C8C;
  width: 100%;
  height: 200rpx;
  padding: 24rpx;
  box-sizing: border-box;
  border-radius: 8rpx;
  margin-bottom: 30rpx;
}

.orange-submit {
  background: #FFA41C;
  color: #0F1111;
  font-weight: bold;
  height: 100rpx;
  line-height: 100rpx;
  border-radius: 50rpx;
  margin-top: 20rpx;
}

/* --- 7. MODAL CHECKOUT --- */
.modal-bg {
  position: fixed;
  top: 0; bottom: 0; left: 0; right: 0;
  background: rgba(0,0,0,0.8);
  display: flex;
  align-items: flex-end;
  z-index: 3000;
}

.modal-content {
  width: 100%;
  background: #fff;
  border-radius: 30rpx 30rpx 0 0;
  padding: 40rpx 40rpx calc(40rpx + env(safe-area-inset-bottom));
}

.modal-title { font-size: 36rpx; font-weight: bold; display: block; margin-bottom: 20rpx; }

.qr-display {
  width: 450rpx;
  height: 450rpx;
  margin: 30rpx auto;
  display: block;
  border: 1rpx solid #eee;
}

.tip {
  font-size: 24rpx;
  color: #565959;
  text-align: center;
  display: block;
  margin-bottom: 30rpx;
}

.yellow-pay {
  background: #FFD814;
  border-radius: 50rpx;
  font-weight: bold;
  height: 90rpx;
  line-height: 90rpx;
}

/* --- 8. EMPTY STATES --- */
.empty-msg {
  padding: 100rpx;
  text-align: center;
  color: #565959;
  font-size: 28rpx;
}