page {
    height: 100%;
    background: #f5f7fa;
  }
  
  .create-page {
    height: 100vh;
    background: #f5f7fa;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }
  
  .page-header {
    background: linear-gradient(135deg, #0ea5e9, #14b8a6);
    padding: 40rpx 30rpx 30rpx;
    display: flex;
    align-items: center;
    justify-content: space-between;
    color: white;
    flex-shrink: 0;
  }
  
  .back-btn {
    font-size: 40rpx;
    width: 60rpx;
  }
  
  .page-title {
    font-size: 36rpx;
    font-weight: bold;
  }
  
  .placeholder {
    width: 60rpx;
  }
  
  .login-section {
    padding: 40rpx;
    text-align: center;
    background: #f5f5f5;
    margin: 20rpx;
    flex-shrink: 0;
  }
  
  .login-text {
    display: block;
    color: #666;
    margin-bottom: 20rpx;
    font-size: 28rpx;
  }
  
  .login-btn {
    background: #07c160;
    color: white;
    border-radius: 40rpx;
    padding: 20rpx 60rpx;
    font-size: 30rpx;
  }
  
  .user-info-section {
    display: flex;
    align-items: center;
    padding: 20rpx;
    background: #e6f7ff;
    margin: 20rpx;
    flex-shrink: 0;
  }
  
  .user-avatar-small {
    width: 60rpx;
    height: 60rpx;
    border-radius: 50%;
    margin-right: 16rpx;
  }
  
  .user-name-small {
    font-size: 28rpx;
    color: #333;
  }
  
  .scroll-area {
    flex: 1;
    width: 100%;
  }
  
  .form-container {
    padding: 20rpx 30rpx 0;
  }
  
  .form-group {
    background: white;
    border-radius: 20rpx;
    padding: 30rpx;
    margin-bottom: 30rpx;
    box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.08);
  }
  
  .label {
    display: block;
    font-size: 30rpx;
    color: #333;
    font-weight: 600;
    margin-bottom: 20rpx;
  }
  
  .picker-box {
    background: #f8f8f8;
    border-radius: 16rpx;
    padding: 28rpx 24rpx;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 30rpx;
    color: #999;
  }
  
  .picker-box.active {
    color: #333;
    background: #e6f7ff;
  }
  
  .arrow {
    font-size: 24rpx;
    color: #999;
  }
  
  .text-input {
    background: #f8f8f8;
    border-radius: 16rpx;
    padding: 24rpx;
    font-size: 30rpx;
    width: 100%;
    box-sizing: border-box;
  }
  
  .textarea-input {
    background: #f8f8f8;
    border-radius: 16rpx;
    padding: 24rpx;
    font-size: 30rpx;
    width: 100%;
    box-sizing: border-box;
    min-height: 200rpx;
  }
  
  .photo-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 20rpx;
  }
  
  .photo-add {
    width: 180rpx;
    height: 180rpx;
    background: #f8f8f8;
    border: 2rpx dashed #ccc;
    border-radius: 16rpx;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }
  
  .add-icon {
    font-size: 60rpx;
    color: #999;
  }
  
  .add-text {
    font-size: 26rpx;
    color: #999;
    margin-top: 10rpx;
  }
  
  .photo-item {
    width: 180rpx;
    height: 180rpx;
    position: relative;
  }
  
  .photo-item image {
    width: 100%;
    height: 100%;
    border-radius: 16rpx;
  }
  
  .photo-delete {
    position: absolute;
    top: -10rpx;
    right: -10rpx;
    width: 44rpx;
    height: 44rpx;
    background: #ff4757;
    color: white;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 32rpx;
  }
  
  .page-footer {
    flex-shrink: 0;
    background: white;
    padding: 20rpx 30rpx;
    padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
    box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.1);
  }
  
  .publish-btn {
    background: #07c160;
    color: white;
    border-radius: 50rpx;
    height: 90rpx;
    line-height: 90rpx;
    font-size: 32rpx;
    font-weight: bold;
    width: 100%;
  }