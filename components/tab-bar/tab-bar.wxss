.tab-bar {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    height: 100rpx;
    background: #ffffff;
    display: flex;
    border-top: 1rpx solid #e5e5e5;
    padding-bottom: env(safe-area-inset-bottom);
    z-index: 9999;
    box-sizing: border-box;
  }
  
  .tab-bar-item {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    height: 100rpx;
    padding: 0;
  }
  
  .tab-emoji {
    font-size: 40rpx;
    margin-bottom: 4rpx;
    line-height: 1;
  }
  
  .tab-text {
    font-size: 20rpx;
    line-height: 1;
  }
  
  /* Active state */
  .tab-bar-item.active .tab-text {
    font-weight: 500;
  }